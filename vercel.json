{
  "version": 2,
  "rewrites": [
    {
      "source": "/token",
      "destination": "backend/main.py"
    },
    {
      "source": "/users(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/tasks(.*)",
      "destination": "backend/main.py"
    },
    {
      "source": "/generate-report",
      "destination": "backend/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}